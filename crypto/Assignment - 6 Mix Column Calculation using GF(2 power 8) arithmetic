#include <bits/stdc++.h>
using namespace std;

int charToByte(char c)
{
    if(c==' ') return 0x20;
    return c-'A';
}

unsigned char gfAdd(unsigned char a,unsigned char b)
{
    return a^b;
}

unsigned char gfMul(unsigned char a,unsigned char b)
{
    unsigned char res=0;

    while(b)
    {
        if(b&1) res^=a;

        if(a&0x80)
            a=(a<<1)^0x1B;
        else
            a<<=1;

        b>>=1;
    }
    return res;
}

// --------- MIX COLUMN ---------
vector<unsigned char> mixColumn(vector<unsigned char> col)
{
    vector<unsigned char> M={0x01,0x02,0x09,0xAD};
    vector<unsigned char> res(4);

    res[0]=gfMul(M[0],col[0]) ^
           gfMul(M[1],col[1]) ^
           gfMul(M[2],col[2]) ^
           gfMul(M[3],col[3]);

    res[1]=gfMul(M[3],col[0]) ^
           gfMul(M[0],col[1]) ^
           gfMul(M[1],col[2]) ^
           gfMul(M[2],col[3]);

    res[2]=gfMul(M[2],col[0]) ^
           gfMul(M[3],col[1]) ^
           gfMul(M[0],col[2]) ^
           gfMul(M[1],col[3]);

    res[3]=gfMul(M[1],col[0]) ^
           gfMul(M[2],col[1]) ^
           gfMul(M[3],col[2]) ^
           gfMul(M[0],col[3]);

    return res;
}

int main()
{
    string pt="ABCDEFGHIJKLMNOP";
    string key="PONMLKJIHGFEDCBA";

    unsigned char state[4][4];
    unsigned char keyM[4][4];

    int k=0;

    // ---------- TASK A ----------
    for(int j=0;j<4;j++)
        for(int i=0;i<4;i++)
            state[i][j]=charToByte(pt[k++]);

    k=0;

    for(int j=0;j<4;j++)
        for(int i=0;i<4;i++)
            keyM[i][j]=charToByte(key[k++]);

    cout<<"STATE MATRIX:\n";
    for(int i=0;i<4;i++)
    {
        for(int j=0;j<4;j++)
            printf("%02X ",state[i][j]);
        cout<<endl;
    }

    // ---------- TASK B ----------
    unsigned char addRes=gfAdd(0xAD,0x2E);
    printf("\nAD + 2E = %02X\n",addRes);

    // ---------- TASK C ----------
    unsigned char mul1=gfMul(0xAD,0x02);
    unsigned char mul2=gfMul(0xAD,0x09);

    printf("AD x 02 = %02X\n",mul1);
    printf("AD x 09 = %02X\n",mul2);

    vector<unsigned char> col={
        state[0][0],
        state[1][0],
        state[2][0],
        state[3][0]
    };

    vector<unsigned char> mixed=mixColumn(col);

    cout<<"\nMIX COLUMN OUTPUT:\n";
    for(auto x:mixed)
        printf("%02X\n",x);
}
