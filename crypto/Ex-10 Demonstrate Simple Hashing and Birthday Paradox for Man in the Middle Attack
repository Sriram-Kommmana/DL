int main() {

    string msg = "Contract Amount 30000 Dollars.";

    cout << "Original Message:\n" << msg << endl;

    // Step 1: Padding
    auto bytes = padMessage(msg);

    cout << "\nPadded Bytes (32 bytes):\n";
    for (auto b : bytes) cout << (int)b << " ";
    cout << endl;

    // Step 2: Create blocks
    auto blocks = createBlocks(bytes);

    cout << "\n16 Blocks (16-bit each):\n";
    for (auto b : blocks) cout << b << " ";
    cout << endl;

    // Step 3: Simple XOR Hash
    uint16_t simpleHash = simpleXORHash(blocks);
    cout << "\nSimple XOR Hash: " << simpleHash << endl;

    // Step 4: Rounded XOR Hash
    uint16_t roundHash = roundedXORHash(blocks);
    cout << "Rounded XOR Hash: " << roundHash << endl;

    // Step 5: RSA Signature
    long long e, d, n;
    generateRSA(e, d, n);

    long long signature = modExp(roundHash, d, n);
    cout << "\nSignature (Encrypted Hash): " << signature << endl;

    // Step 6: Verification
    long long decryptedHash = modExp(signature, e, n);
    cout << "Decrypted Hash: " << decryptedHash << endl;

    if (decryptedHash == roundHash)
        cout << "Signature VERIFIED\n";
    else
        cout << "Signature INVALID\n";

    /* ---------------- TASK 2 ---------------- */

    string m1 = "Contract Amount 30000 Dollars.";
    string m2 = "Contract Amount 40000 Dollars.";

    birthdayAttack(m1, m2);

    return 0;
}
