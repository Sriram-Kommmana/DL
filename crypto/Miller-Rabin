#include <bits/stdc++.h>
using namespace std;

// Modular exponentiation
long long power(long long a, long long d, long long n)
{
    long long result = 1;
    a = a % n;

    while (d > 0)
    {
        if (d % 2 == 1)
            result = (result * a) % n;

        d = d / 2;
        a = (a * a) % n;
    }
    return result;
}

// Miller Test
bool millerTest(long long d, long long n)
{
    long long a = 2 + rand() % (n - 4);
    long long x = power(a, d, n);

    if (x == 1 || x == n - 1)
        return true;

    while (d != n - 1)
    {
        x = (x * x) % n;
        d *= 2;

        if (x == 1)
            return false;

        if (x == n - 1)
            return true;
    }
    return false;
}

// Check Prime
bool isPrime(long long n, int k)
{
    if (n <= 1 || n == 4)
        return false;
    if (n <= 3)
        return true;

    long long d = n - 1;
    while (d % 2 == 0)
        d /= 2;

    for (int i = 0; i < k; i++)
        if (!millerTest(d, n))
            return false;

    return true;
}

int main()
{
    long long n;
    cout << "Enter number to check: ";
    cin >> n;

    int k = 5;

    if (isPrime(n, k))
        cout << n << " is PRIME" << endl;
    else
        cout << n << " is COMPOSITE" << endl;

    return 0;
}
